{
  "manifest_version": 3,
  "name": "TextClip",
  "version": "1.0.2",
  "description": "Clip text from any webpage with right-click. Organize into folders. Summarize with your AI — all stored locally.",
  "permissions": [
    "contextMenus",
    "storage",
    "unlimitedStorage",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TextClip"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline';"
  }
}
